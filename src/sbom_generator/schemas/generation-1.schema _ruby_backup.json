{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TODO",
  "title": "SBOM Generation Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "sources",
    "targets"
  ],
  "properties": {
    "version": {
      "enum": [
        1
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/sourceGit"
          },
          {
            "$ref": "#/$defs/sourceLocal"
          },
          {
            "$ref": "#/$defs/sourceDocker"
          }
        ]
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/targetNPM"
          },
          {
            "$ref": "#/$defs/targetYarn"
          },
          {
            "$ref": "#/$defs/targetRuby"
          },
          {
            "$ref": "#/$defs/targetDocker"
          }
        ]
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "sourceBase": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string"
        }
      }
    },
    "sourceGit": {
      "allOf": [
        {
          "$ref": "#/$defs/sourceBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "url",
            "ref",
            "cloneDir"
          ],
          "properties": {
            "type": {
              "const": "git"
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "cloneDir": {
              "type": "string",
              "not": {
                "enum": [
                  ".",
                  "..",
                  "/",
                  "~/"
                ]
              },
              "description": "Relative path to directory of configuration file."
            }
          }
        }
      ]
    },
    "sourceLocal": {
      "allOf": [
        {
          "$ref": "#/$defs/sourceBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "local"
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "description": "Relative path to directory of configuration file."
            }
          }
        }
      ]
    },
    "sourceDocker": {
      "allOf": [
        {
          "$ref": "#/$defs/sourceBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "image",
            "tag"
          ],
          "properties": {
            "type": {
              "const": "docker"
            },
            "image": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "targetBase": {
      "type": "object",
      "required": [
        "id",
        "type",
        "generation",
        "sourceId"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "type": "string"
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "options": {
          "type": "object"
        },
        "generation": {
          "$ref": "#/$defs/generationOptionsBase"
        }
      }
    },
    "targetNPM": {
      "allOf": [
        {
          "$ref": "#/$defs/targetBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "options",
            "generation"
          ],
          "properties": {
            "type": {
              "const": "npm"
            },
            "generation": {
              "$ref": "#/$defs/generationOptionsNPM"
            },
            "options": {
              "$ref": "#/$defs/optionsNPM"
            }
          }
        }
      ]
    },
    "targetYarn": {
      "allOf": [
        {
          "$ref": "#/$defs/targetBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "options",
            "generation"
          ],
          "properties": {
            "type": {
              "const": "yarn"
            },
            "generation": {
              "$ref": "#/$defs/generationOptionsYarn"
            },
            "options": {
              "$ref": "#/$defs/optionsYarn"
            }
          }
        }
      ]
    },
    "targetRuby": {
      "allOf": [
        {
          "$ref": "#/$defs/targetBase"
        },
        {
          "type": "object",
          "required": [
            "type",
            "options",
            "generation"
          ],
          "properties": {
            "type": {
              "const": "ruby"
            },
            "generation": {
              "$ref": "#/$defs/generationOptionsRuby"
            },
            "options": {
              "$ref": "#/$defs/optionsRuby"
            }
          }
        }
      ]
    },
    "targetDocker": {
      "allOf": [
        {
          "$ref": "#/$defs/targetBase"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "docker"
            }
          }
        }
      ]
    },
    "generationOptionsBase": {
      "type": "object",
      "required": [
        "outputPath",
        "format",
        "specVersion"
      ],
      "properties": {
        "outputPath": {
          "description": "Absolute path or relative path to directory of configuration file.",
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string"
        },
        "specVersion": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "properties": {
            "format": {
              "const": "xml"
            },
            "specVersion": {
              "enum": [
                "1.0",
                "1.1",
                "1.2",
                "1.3",
                "1.4",
                "1.5",
                "1.6",
                "1.7"
              ]
            }
          }
        },
        {
          "properties": {
            "format": {
              "const": "json"
            },
            "specVersion": {
              "enum": [
                "1.2",
                "1.3",
                "1.4",
                "1.5",
                "1.6",
                "1.7"
              ]
            }
          }
        },
        {
          "properties": {
            "format": {
              "const": "proto"
            },
            "specVersion": {
              "enum": [
                "1.3",
                "1.4",
                "1.5",
                "1.6",
                "1.7"
              ]
            }
          }
        }
      ]
    },
    "generationOptionsNPM": {
      "allOf": [
        {
          "$ref": "#/$defs/generationOptionsBase"
        },
        {
          "required": [
            "format",
            "specVersion"
          ],
          "properties": {
            "format": {
              "enum": [
                "json",
                "xml"
              ]
            },
            "specVersion": {
              "enum": [
                "1.2",
                "1.3",
                "1.4",
                "1.5",
                "1.6"
              ]
            }
          }
        }
      ]
    },
    "generationOptionsYarn": {
      "allOf": [
        {
          "$ref": "#/$defs/generationOptionsBase"
        },
        {
          "required": [
            "format",
            "specVersion"
          ],
          "properties": {
            "format": {
              "enum": [
                "json",
                "xml"
              ]
            },
            "specVersion": {
              "enum": [
                "1.2",
                "1.3",
                "1.4",
                "1.5",
                "1.6",
                "1.7"
              ]
            }
          }
        }
      ]
    },
    "generationOptionsRuby": {
      "allOf": [
        {
          "$ref": "#/$defs/generationOptionsBase"
        },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "format": {
                  "const": "xml"
                },
                "specVersion": {
                  "enum": [
                    "1.1",
                    "1.2",
                    "1.3",
                    "1.4",
                    "1.5",
                    "1.6",
                    "1.7"
                  ]
                }
              },
              "required": [
                "format",
                "specVersion"
              ]
            },
            {
              "type": "object",
              "properties": {
                "format": {
                  "const": "json"
                },
                "specVersion": {
                  "enum": [
                    "1.2",
                    "1.3",
                    "1.4",
                    "1.5",
                    "1.6",
                    "1.7"
                  ]
                }
              },
              "required": [
                "format",
                "specVersion"
              ]
            }
          ]
        }
      ]
    },
    "optionsNPM": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "lockOnly",
        "includeDev",
        "includePeer",
        "includeOptional",
        "flatten",
        "mainType"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "The path of the 'package.json' manifest, relative to source (root) path."
        },
        "lockOnly": {
          "type": "boolean",
          "description": "Use only the 'npm-shrinkwrap.json' or 'package-lock.json' lockfiles."
        },
        "includeDev": {
          "type": "boolean"
        },
        "includeOptional": {
          "type": "boolean"
        },
        "includePeer": {
          "type": "boolean"
        },
        "flatten": {
          "type": "boolean"
        },
        "mainType": {
          "enum": [
            "application",
            "firmware",
            "library"
          ]
        }
      }
    },
    "optionsYarn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "includeDev",
        "mainType"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "The path of the 'package.json' manifest, relative to source (root) path."
        },
        "includeDev": {
          "type": "boolean"
        },
        "mainType": {
          "enum": [
            "application",
            "firmware",
            "library"
          ]
        }
      }
    },
    "optionsRuby": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "The path of the 'Gemfile' manifest, relative to source (root) path."
        }
      }
    }
  }
}